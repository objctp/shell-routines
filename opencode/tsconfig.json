{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["node"],
    "outDir": "dist",
    "noEmit": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
  },
  "include": ["plugins/**/*.ts"],
  "exclude": ["node_modules", "dist"],
}
